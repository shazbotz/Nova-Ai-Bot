# ==========================================
# AI Assistant Telegram Bot - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/aibot
ADMIN_TELEGRAM_ID=your_telegram_numeric_user_id

# ── Mini App ──────────────────────────────
# This service serves the built Mini App itself at /app, so set this to
# your own Koyeb service URL + /app once deployed, e.g.:
#   MINI_APP_URL=https://your-service.koyeb.app/app
# (enables the "Open AI Chat" button in /start, /chat and /plan)
# Leave blank to run bot-only.
MINI_APP_URL=https://your-service.koyeb.app/app

# ── Admin Dashboard ────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_secure_password
SESSION_SECRET=change_this_to_random_secret_string
ADMIN_PORT=5000

# ── AI Providers (add at least one) ────────
# OpenAI — also powers /imagine image generation (DALL-E 3)
OPENAI_API_KEY=sk-...

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# Groq (free tier available)
GROQ_API_KEY=gsk_...

# ── Optional ──────────────────────────────
LOG_LEVEL=info
DEFAULT_AI_MODEL=openai/gpt-4o-mini

# ── Features ───────────────────────────────
# Image generation via /imagine — requires OPENAI_API_KEY (DALL-E 3).
# No extra key needed — uses the same OPENAI_API_KEY above.

# ZIP file support — built-in, no extra key needed.
# Users can send .zip files; the bot extracts & reads all text/code files inside.
